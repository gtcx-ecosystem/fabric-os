{
  "$schema": "gtcx://ecosystem-os/graph-config/v1",
  "repo": "fabric-os",
  "entities": [
    {
      "type": "repo",
      "source": "package.json"
    },
    {
      "type": "fabric-product",
      "source": "pm/manifest.json"
    },
    {
      "type": "deployment-control-plane",
      "source": "deploy/"
    },
    {
      "type": "service-fabric",
      "source": "platform/tools/control-plane/"
    },
    {
      "type": "security-assurance",
      "source": "docs/operations/secas/"
    },
    {
      "type": "evidence",
      "source": "audit/evidence/*.json"
    }
  ],
  "relations": [
    {
      "type": "implements",
      "source": "platform/"
    },
    {
      "type": "validated_by",
      "source": "audit/evidence/rag-eval-latest.json"
    },
    {
