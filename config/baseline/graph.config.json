      "source": "package.json"
    },
    {
      "type": "operates",
      "source": "docs/operations/platform-services/"
    }
  ],
  "evidencePaths": [
    "audit/evidence/rag-config-latest.json",
    "audit/evidence/rag-eval-latest.json",
    "audit/evidence/mcp-config-latest.json",
    "audit/evidence/graph-projection-latest.json",
    "audit/evidence/eval-config-latest.json"
  ],
  "exclude": [".git/**", ".worktrees/**", "node_modules/**", "audit/archive/**"]
}
