{
  "$schema": "./root-allowlist.schema.json",
  "version": "5.0.0",
  "schema_version": "5.0.0",
  "updated": "2026-06-22",
  "description": "P35 v5 closed-world repo root allowlist for fabric-os.",
  "migration_tier": "stable",
  "required_files": ["README.md", "AGENTS.md", "CHANGELOG.md"],
  "required_directories": [
    "archive",
    "docs",
    "operations",
    "platform",
    "deploy",
    "audit",
    "workstream",
    "config",
    "agentic",
    "agents",
    "agile",
    "machine",
    "ops",
    "pm"
  ],
  "allowed_files": [
    "LICENSE",
    "NOTICE",
    "CHANGELOG.md",
    "package.json",
    "pnpm-workspace.yaml",
    "pnpm-lock.yaml",
    "turbo.json",
    "tsconfig.json",
    "eslint.config.js",
    "commitlint.config.js",
    "baseline.config.json",
    "hygiene.config.json",
    "pyproject.toml",
    "Cargo.toml",
    "Makefile",
    "Makefile.local",
    "lighthouserc.js",
    "vitest.workspace.ts"
  ],
  "allowed_directories": [
    "archive",
    "docs",
    "operations",
    "platform",
    "deploy",
    "audit",
    "workstream",
    "config",
    "agentic",
    "agents",
    "agile",
    "machine",
    "ops",
    "pm"
  ],
  "allowed_dot_directories": [
    ".github",
    ".husky",
    ".agent",
    ".baseline",
    ".cursor",
    ".claude",
    ".gemini",
    ".kimi",
    ".gtcx",
    ".turbo",
    ".changeset",
    ".zap"
  ],
  "ignored_prefixes": [".", "node_modules"],
  "ignored_exact": ["node_modules", "tsconfig.tsbuildinfo"],
  "permissible_on_approval": {},
  "forbidden_root_names": {
    "00-archive": "Use archive/ (P35 v5).",
    "01-docs": "Use docs/ (P35 v5).",
    "02-ops": "Use operations/ (P35 v5).",
    "03-platform": "Use platform/ (P35 v5).",
    "04-deploy": "Use deploy/ (P35 v5).",
    "05-audit": "Use audit/ (P35 v5).",
    "06-workstream": "Use workstream/ (P35 v5).",
    "04-ship": "Use deploy/ (P35 v5).",
    "CLAUDE.md": "Use .claude/CLAUDE.md (agent-sync).",
    "GEMINI.md": "Use .gemini/GEMINI.md.",
    "KIMI.md": "Use .kimi/AGENTS.md.",
    "CODEX.md": "Use AGENTS.md + .agent/.",
    "CONVENTIONS.md": "Use docs/conventions.md.",
    "CODE_OF_CONDUCT.md": "Use docs/operations/repo/CODE_OF_CONDUCT.md.",
    "CONTRIBUTING.md": "Use docs/operations/repo/CONTRIBUTING.md.",
    "SECURITY.md": "Use docs/operations/repo/SECURITY.md.",
    "apps": "Use platform/apps/.",
    "packages": "Use platform/packages/.",
    "services": "Use platform/services/.",
    "infra": "Use deploy/ or platform/.",
    "gtcx-agent": "Use workstream/agent-feedback/ (P35 v5).",
    "playwright-report": "Use platform/e2e/.artifacts/playwright-report/.",
    "test-results": "Use platform/e2e/.artifacts/test-results/.",
    "scripts": "Use platform/scripts/.",
    "gtcx-logo.png": "Use platform/assets/.",
    ".eslintrc.js": "Use config/toolchain/eslint.config.js + root re-export (P35 toolchain).",
    ".eslintrc.json": "Use config/toolchain/eslint.config.js + root re-export (P35 toolchain).",
    ".eslintignore": "Use eslint.config.js ignores block (P35 toolchain)."
  },
  "forbidden_name_prefixes": ["IMG_", "Screenshot", "Untitled"],
  "human_owned_paths": {},
  "relocate_hints": {
    "audits": "audit/",
    "repo_policy": "docs/operations/repo/",
    "p29_domains": "operations/"
