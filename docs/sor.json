{
  "$schema": "gtcx://docs/sor/v1",
  "schema": "gtcx.docs.sor.v1",
  "repo": "fabric-os",
  "repoKind": "platform-runtime",
  "updated": "2026-06-16",
  "narrativeRoot": "docs/",
  "rootSorMap": "config/sor-map.json",
  "layoutContract": "config/layout-contract.json",
  "upstream": {
    "constitution": {
      "repo": "gtcx-docs",
      "path": "../gtcx-docs",
      "manifest": "../canon-os/config/ecosystem-central-sor.json",
      "role": "protocols and audit-engine specs — read-only"
    },
    "platform": {
      "repo": "bridge-os",
      "path": "../bridge-os",
      "layoutContract": "../bridge-os/config/ecosystem-layout-contract.json",
      "role": "fleet layout and rollout — read-only"
    },
    "runtime": {
      "repo": "baseline-os",
      "path": "../baseline-os",
      "role": "session, MCP, ACR — read-only"
    }
  },
  "allowedTopLevel": [
    "foundation",
    "api",
    "architecture",
    "_archive",
    "gitbook",
    "governance",
    "operations",
    "primitives",
    "product",
    "publishing",
    "reference",
    "research",
    "roadmap",
    "business"
  ],
  "narrativePointersOnly": ["assurance", "coordination", "gtm", "legal", "security"],
  "documentDriven": {
    "description": "Human-edited narrative under docs/ — version in git",
    "paths": [
      "docs/README.md",
      "docs/INDEX.md",
      "docs/foundation/",
      "docs/conventions.md",
      "docs/architecture/",
      "docs/operations/",
      "docs/roadmap/",
      "docs/business/"
    ]
  },
  "pointerOnly": {
    "description": "Stub or index — canonical prose lives in gtcx-docs or operations/",
    "paths": ["docs/governance/", "docs/reference/", "docs/specs/"]
  },
  "shipPaths": {
    "terraform": "deploy/terraform",
    "kubernetes": "deploy/kubernetes",
    "docker": "deploy/docker",
    "monitoring": "deploy/monitoring",
    "platformScripts": "platform/scripts"
  },
  "forbidden": {
    "numberedSegments": "^\\d{2}-",
    "shadowAsAuthority": ["docs/shadow/", "archive/shadow-gtcx-docs/"],
    "competingRoots": ["_sop/", "_canon/", "wiki/"],
    "opsDuplicatesUnderDocs": [
      "assurance",
      "attestation",
      "coordination",
      "gtm",
      "legal",
      "security",
      "witness"
    ]
  },
  "engineDriven": {
    "note": "Not stored under docs/ — see machine/manifest.json (P36)",
    "manifest": "machine/manifest.json"
  },
  "iaExemptions": {
    "denseExemptPathPrefixes": [
      "docs/operations",
      "docs/operations/batch-a",
      "docs/operations/batch-b",
      "docs/operations/batch-c",
      "docs/operations/coordination",
      "docs/reference/archive",
      "docs/reference/audits",
      "docs/architecture/specs",
      "docs/architecture/specs/product-scopes",
      "docs/business/strategy",
      "docs/business/research",
      "docs/specs",
      "docs/architecture/specs/layers",
      "docs/architecture/specs/layers/packs",
      "docs/architecture/specs/layers/guides",
      "docs/reference/skills",
      "docs/_archive",
      "docs/primitives",
      "docs/publishing",
      "docs/research",
      "docs/engineering",
      "docs/operations/core-ops",
      "docs/operations/platform-services",
      "docs/operations/secas",
      "docs/operations/workspace",
      "docs/architecture/specs/_project",
      "docs/reference/archived"
    ],
    "folderSpecExemptPathPrefixes": [
      "docs/_archive",
      "docs/engineering",
      "docs/strategy",
      "docs/roadmap"
    ],
    "depthExemptPathPrefixes": [
      "docs/architecture/operations",
      "docs/architecture/specs/_project",
      "docs/architecture/specs/architecture",
      "docs/architecture/specs/layers",
      "docs/architecture/specs/operations",
      "docs/gitbook/business",
      "docs/reference/archive",
      "docs/reference/templates",
      "docs/architecture/specs/layers/packs",
      "docs/operations/compliance/evidence",
      "docs/reference/archived"
    ],
    "shadowExemptPathPrefixes": [
      "docs/reference/architecture",
      "docs/reference/operations",
      "docs/operations/governance"
    ],
    "readmeExemptPathPrefixes": ["docs/reference/archive"]
  },
  "deprecatedTopLevel": ["specs", "strategy", "overview", "engineering"]
}
