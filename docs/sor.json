{
  "$schema": "gtcx://docs/sor/v1",
  "schema": "gtcx.docs.sor.v1",
  "repo": "fabric-os",
  "repoKind": "infra-platform",
  "updated": "2026-06-16",
  "narrativeRoot": "docs/",
  "rootSorMap": "config/sor-map.json",
  "layoutContract": "config/layout-contract.json",
  "upstream": {
    "constitution": {
      "repo": "gtcx-docs",
      "path": "../gtcx-docs",
      "manifest": "../canon-os/config/ecosystem-central-sor.json",
      "role": "protocols and audit-engine specs — read-only"
    },
    "platform": {
      "repo": "bridge-os",
      "path": "../bridge-os",
      "layoutContract": "../bridge-os/config/ecosystem-layout-contract.json",
      "role": "fleet layout and rollout — read-only"
    },
    "runtime": {
      "repo": "baseline-os",
      "path": "../baseline-os",
      "role": "session, MCP, ACR — read-only"
    }
  },
  "allowedTopLevel": [
    "foundation",
    "api",
    "architecture",
    "engineering",
    "gitbook",
    "governance",
    "operations",
    "reference",
    "roadmap",
    "business"
  ],
  "narrativePointersOnly": ["assurance", "coordination", "gtm", "legal", "security"],
  "documentDriven": {
    "description": "Human-edited narrative under docs/ — version in git",
    "paths": [
      "docs/README.md",
      "docs/INDEX.md",
      "docs/foundation/",
      "docs/conventions.md",
      "docs/architecture/",
      "docs/operations/",
      "docs/roadmap/",
      "docs/business/"
    ]
  },
  "pointerOnly": {
    "description": "Stub or index — canonical prose lives in gtcx-docs or ops/",
    "paths": ["docs/governance/", "docs/reference/", "docs/specs/"]
  },
  "shipPaths": {
    "terraform": "deploy/terraform",
    "kubernetes": "deploy/kubernetes",
    "docker": "deploy/docker",
    "monitoring": "deploy/monitoring",
    "platformScripts": "platform/scripts"
  },
  "forbidden": {
    "numberedSegments": "^\\d{2}-",
    "shadowAsAuthority": ["docs/shadow/", "archive/shadow-gtcx-docs/"],
    "competingRoots": ["_sop/", "_canon/", "wiki/"],
    "opsDuplicatesUnderDocs": [
      "assurance",
      "attestation",
      "coordination",
      "gtm",
      "legal",
      "security",
      "witness"
    ]
  },
  "engineDriven": {
    "note": "Not stored under docs/ — see pm/manifest.json (P36)",
    "manifest": "pm/manifest.json"
  },
  "iaExemptions": {
    "denseExemptPathPrefixes": [
      "docs/operations",
      "docs/operations/batch-a",
      "docs/operations/batch-b",
      "docs/operations/batch-c",
      "docs/operations/coordination",
      "docs/reference/archive",
      "docs/reference/audits",
      "docs/architecture/specs",
      "docs/architecture/specs/product-scopes",
      "docs/business/strategy",
      "docs/business/research",
      "docs/specs"
    ],
    "readmeExemptPathPrefixes": ["docs/reference/archive"],
    "depthExemptPathPrefixes": ["docs/reference/archive", "docs/reference/templates"]
  }
}
