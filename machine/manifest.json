{
  "$schema": "gtcx://pm/manifest/v5",
  "schema": "gtcx.pm.manifest.v5",
  "repo": "fabric-os",
  "layoutVersion": "v5",
  "updated": "2026-06-09",
  "agileHub": null,
  "ux": "machine/ux",
  "product": "machine/product",
  "local": {
    "executionRoadmap": "audit/product-management/execution-roadmap.md",
    "workSelection": "docs/operations/agent-work-selection.md",
    "autoDevState": "audit/product-management/auto-dev-state.md",
    "nextWorkScript": "platform/scripts/agent-next-work.mjs",
    "completionModel": "machine/completion-model.json",
    "initiatives": "machine/roadmap/initiatives.json"
  },
  "sync": {
    "command": "pnpm machine:sync",
    "output": "operations/machine/backlog.json"
  },
  "generate": {
    "daas": {
      "command": "pnpm generate:roadmap",
      "sources": [
        "machine/daas-roadmap.json",
        "machine/friction-register.json",
        "machine/daas-stories.json"
      ],
      "output": "audit/product-management/execution-roadmap.md"
    },
    "secas": {
      "command": "pnpm generate:secas-roadmap",
      "sources": [
        "machine/secas-roadmap.json",
        "machine/security-friction-register.json",
        "machine/secas-stories.json",
        "machine/sovereign-approval-register.json"
      ],
      "output": "audit/product-management/secas-execution-roadmap.md"
    }
  }
}
