        "templates",
        "monitoring",
        "runtime",
        "compliance",
        "daas",
        "core-ops",
        "platform-services",
        "secas",
        "fleet-ops-assurance",
        "protocols",
        "legal",
        "release-management"
      ],
      "subfolderContractEnforced": true,
      "complianceNestSpec": "machine/spec/docs-operations-compliance-nest.json",
      "complianceNestCheck": "pnpm docs:compliance-nest:check",
      "note": "fabric-os, gtcx-os. compliance/ allowed. fabric-only zones via iaExtensions on fabric-os."
    },
    "platform": {
      "operationsRequired": true,
      "requiredSubfolders": [],
      "optionalSubfolders": [
        "runbooks",
        "playbooks",
        "incidents",
        "on-call",
        "agent-init",
        "deployment",
        "remediation",
        "coordination",
        "repo",
        "workspace",
        "templates",
        "monitoring",
        "runtime"
      ],
      "subfolderContractEnforced": true
    },
    "product": {
      "operationsRequired": true,
      "requiredSubfolders": [],
      "optionalSubfolders": [
        "runbooks",
        "playbooks",
        "incidents",
        "on-call",
        "agent-init",
        "deployment",
        "remediation",
        "coordination",
        "repo",
        "workspace",
        "templates",
        "monitoring",
        "runtime",
        "compliance",
        "evidence",
        "pilot-kit"
      ],
      "subfolderContractEnforced": true,
      "note": "14 product repos. Consume fabric-os ops via links — don't host provider zones."
    },
    "fleet-documentation": {
      "operationsRequired": true,
      "requiredSubfolders": [],
      "optionalSubfolders": [
        "runbooks",
        "agent-init",
        "coordination",
        "deployment",
        "remediation",
        "playbooks",
        "incidents",
        "on-call"
      ],
      "subfolderContractEnforced": true
    },
    "constitution-standards": {
      "operationsRequired": false,
      "allowed": "docs/operations/README.md pointer to ecosystem-os + canon-os ops narratives"
    }
  },
  "crossReference": {
    "opsMachineSoR": "operations/",
    "foundationLinks": [
      {
        "foundation": "goals.md",
        "operations": "runbooks/"
      }
    ],
    "referenceDecompose": {
      "docs/_archive/guides/": "relocate → docs/operations/runbooks/; pointer at _archive"
    }
  },
  "enforcement": {
    "check": "pnpm docs:operations:check",
    "fleetCheck": "pnpm ecosystem:docs:operations:fleet",
    "witness": "audit/evidence/docs-operations-latest.json",
    "fleetWitness": "audit/evidence/fleet-docs-operations-latest.json",
    "bootstrap": "node platform/scripts/fleet-docs-operations-bootstrap.mjs --write --all"
  },
  "repo": "fabric-os",
  "upstreamSpec": "../canon-os/pm/spec/docs-operations-pack.json",
  "pillarContract": {
    "compliance": {
      "primary": true,
      "artifacts": ["docs/operations/README.md", "machine/spec/docs-operations-pack.json"],
      "gates": ["pnpm docs:operations:check"],
      "minBar": "≥100 layer order; reference hubs 100",
      "witness": "audit/evidence/mpr-operations-layer-latest.json"
    },
    "technicalExcellence": {
