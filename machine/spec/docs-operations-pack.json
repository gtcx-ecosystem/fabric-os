{
  "$schema": "gtcx://canon-os/docs-operations-pack/v1",
  "updated": "2026-06-20",
  "initiative": "INIT-DOCS-CORE-IA-V1",
  "title": "Docs operations pack — fabric-os",
  "principle": "Human runbooks and agent ops narrative live under docs/operations/. P29 machine manifests stay under operations/ — link only, never duplicate domain state.",
  "fabricContract": {
    "referenceImplRepo": "baseline-os",
    "opsFunctionProvider": "fabric-os",
    "referencePath": "docs/operations/",
    "subfolderContract": "machine/spec/docs-operations-subfolder-contract.json",
    "consumptionModel": "Local repos CONSUME fabric-os ops-as-a-service (deployment P40, DaaS P41, SECaaS P42, complianceops P50, mlops P52, aiops P53) via operations/fabric-contract.json + coordination/from-fabric-os-*.md — never duplicate. fabric-only provider zones (core-ops, platform-services, secas) forbidden in local repos.",
    "fabricOnlyZones": ["core-ops", "platform-services", "secas"]
  },
  "requiredRootFiles": [
    {
      "path": "docs/operations/README.md",
      "role": "index + central spec link (05-operations.json) + cross-ref (foundation ↔ operations ↔ operations/)"
    }
  ],
  "requiredSubfolders": {
    "runbooks": {
      "purpose": "Operator runbooks — deployment, incident, recovery",
      "allowedDocTypes": ["runbook", "architecture"],
      "required": ["README.md"],
      "sourcePatterns": ["docs/_archive/guides/", "docs/reference/guides/"]
    },
    "deployment": {
      "purpose": "Release and environment narratives — links operations/deploy bindings",
      "allowedDocTypes": ["runbook", "architecture"],
      "required": ["README.md"]
    },
    "agent-init": {
      "purpose": "Repo agent entry — session start, P22/P27 prose, git workflow. Fleet init → canon-os AGENT-INIT-CANON.",
      "allowedDocTypes": ["runbook", "overview"],
      "required": ["README.md"],
      "canonicalFiles": ["agent-universal-instructions.md"],
      "sourcePatterns": ["agents/", "docs/operations/agent-universal-instructions.md"]
    },
    "remediation": {
      "purpose": "Incident remediation playbooks — narrative only",
      "allowedDocTypes": ["runbook"],
      "required": ["README.md"],
      "optional": true
    },
    "coordination": {
      "purpose": "Cross-repo coordination narratives — bridge handoffs",
      "allowedDocTypes": ["runbook", "overview"],
      "required": ["README.md"],
      "optional": true,
      "hubNote": "canon-os + bridge-os host fleet coordination indexes"
    },
    "compliance": {
      "purpose": "Platform-runtime typed compliance instance artifacts — see docs-operations-compliance-nest.json",
      "allowedDocTypes": ["runbook", "overview", "assessment"],
      "required": ["README.md"],
      "optional": true,
      "platformRuntimeOnly": true,
      "nestSpec": "machine/spec/docs-operations-compliance-nest.json"
    },
    "repo": {
      "purpose": "Repo-specific ops config — CONTRIBUTING, SECURITY, hygiene protocol",
      "allowedDocTypes": ["overview", "runbook"],
      "required": ["README.md"],
      "optional": true
    },
    "legal": {
      "purpose": "Release legal applicability and activation boundary records for release-management proof packs",
      "allowedDocTypes": ["release-evidence", "runbook"],
      "required": ["README.md"],
      "optional": true,
      "platformRuntimeOnly": true
    },
    "release-management": {
      "purpose": "Release proof packs, evidence maps, surface inventories, and release-manager operating records",
      "allowedDocTypes": ["release-evidence", "runbook"],
      "required": ["README.md"],
      "optional": true,
      "platformRuntimeOnly": true
    },
    "workspace": {
      "purpose": "Fleet workspace layout and multi-repo Cursor notes",
      "allowedDocTypes": ["overview", "runbook"],
      "required": ["README.md"],
      "optional": true
    },
    "templates": {
      "purpose": "Reusable ops document templates (not agent-init session templates)",
      "allowedDocTypes": ["overview", "runbook"],
      "required": ["README.md"],
      "optional": true
    }
  },
  "subfolderContractSpec": "machine/spec/docs-operations-subfolder-contract.json",
  "forbiddenAtOperationsRoot": [
    "Duplicate operations/ domain manifests (compliance, security, gtm JSON)",
    "Protocol bodies — belongs in docs/governance/protocols/",
    "Loose narrative *.md except README.md and scorecard.md when subfolders exist"
  ],
  "profileDefaults": {
    "requiredRootFiles": ["README.md"],
    "requiredSubfolders": [],
    "optionalSubfolders": [
      "runbooks",
      "playbooks",
      "incidents",
      "on-call",
      "agent-init",
      "deployment",
      "remediation",
      "coordination",
      "repo",
      "workspace",
      "templates",
      "monitoring",
      "runtime"
    ],
    "note": "Only README + archive required (consistency with engineering). Zones optional-but-contracted — present with real content, identical format when present. compliance/ is platform-runtime only. fabric-only zones (core-ops, platform-services, secas) forbidden in local repos."
  },
  "profiles": {
    "reference-impl-primitives": {
      "operationsRequired": true,
      "requiredSubfolders": [],
      "optionalSubfolders": [
        "runbooks",
        "playbooks",
        "incidents",
