  "extensionRule": "Zones beyond this contract require a docs/sor.json iaExtensions declaration with a stated reason. Undeclared extra zone → gate FAIL.",
  "fabricConsumption": {
    "note": "fabric-os is the fleet DevOps/Ops-as-a-Service PROVIDER. A local repo's operations/ CONSUMES these functions — it does not duplicate them. Reference IMPLEMENTATION (structure) = baseline-os; ops-function PROVIDER = fabric-os. Consumption is non-blocking (blocksIR: false).",
    "machineBinding": "operations/fabric-contract.json (repo root) — what this repo consumes; docs/operations/ links to it, never duplicates.",
    "linkZones": {
      "deployment": "Local deployment runbooks LINK fabric-os deployment choreography (Protocol 40). Local bindings in operations/deployment-profile.json.",
      "coordination": "Holds inbound from-fabric-os-*.md acknowledgements + outbound handoffs (Protocol 44 fabric-consumption).",
      "compliance": "Links fabric-os compliance substrate + compliance-os policy (Protocol 50). Platform-runtime only."
    },
    "doNotDuplicate": [
      "DaaS / SECaaS narrative (link fabric-os platform-services/)",
      "Supply-chain / vendor assurance (link fabric-os secas/)",
      "Compliance control register (link compliance-os + fabric-os attestation)",
      "Friction registers (consume fabric-os/pm/spec/*-friction-register.json via operations/)"
    ],
    "services": {
      "deployment-choreography": "P40 — fabric-os",
      "devops-as-a-service": "P41 — fabric-os",
      "security-as-a-service": "P42 — fabric-os",
      "fabric-consumption": "P44 — consumption contract",
      "complianceops-as-a-service": "P50 — compliance-os + fabric-os substrate",
      "mlops-as-a-service": "P52 — baseline-os lane + fabric-os substrate",
      "aiops-as-a-service": "P53 — bridge-os program + fabric-os substrate"
    }
  },
  "fabricOnlyZones": {
    "note": "These are fabric-os's PROVIDER zones — allowed ONLY on fabric-os via docs/sor.json iaExtensions. Forbidden in product/local repos (consume via links instead).",
    "zones": ["core-ops", "platform-services", "secas"],
    "rule": "A product repo with any of these → gate FAIL (it should be consuming, not hosting the provider zone)."
  },
  "fabricContract": {
    "referenceImplRepo": "baseline-os",
    "opsFunctionProvider": "fabric-os",
    "referencePath": "docs/operations/",
    "machineSoR": "operations/ (repo root)"
  },
  "enforcement": {
    "check": "pnpm docs:operations:check",
    "witness": "audit/evidence/docs-operations-latest.json",
    "enforces": [
      "zone presence",
      "required README",
      "allowlist",
      "filename format (filePatternRegex)"
    ]
  }
