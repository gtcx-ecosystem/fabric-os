  "decomposeMatrix": {
    "sprints": "agile/ (repo root)",
    "agile": "agile/ (repo root)",
    "scrum": "agile/ (repo root)",
    "gtm": "docs/strategy/go-to-market.md",
    "vendor-relations": "docs/primitives/business/",
    "agent-providers": "docs/operations/coordination/ or docs/primitives/business/",
    "specs": "docs/engineering/",
    "audit": "audit/evidence/ (repo root — link only)",
    "evidence": "audit/evidence/ (repo root — link only)",
    "batch-a": "docs/archive/",
    "batch-b": "docs/archive/",
    "batch-c": "docs/archive/",
    "reference-mirror": "docs/archive/",
    "dashboards": "docs/operations/monitoring/",
    "analytics": "docs/operations/monitoring/",
    "ux": "docs/product/ux/",
    "accessibility": "docs/product/ux/",
