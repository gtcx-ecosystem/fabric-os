{
  "$schema": "gtcx://canon-os/docs-operations-subfolder-contract/v3",
  "version": "3.0.0",
  "updated": "2026-06-21",
  "initiative": "INIT-DOCS-CORE-IA-V1",
  "repo": "fabric-os",
  "role": "platform-runtime-local-contract",
  "ratifiedSpec": "docs/governance/docs-ia/proposals/DOCS-ENGINEERING-OPERATIONS-SPEC-2026-06-21.md",
  "principle": "operations/ = HOW IT'S RUN (narrative). Machine state stays in operations/ (repo root) — link only. Every zone provisioned: README + declared format + allowlist. Only README + archive required; zones optional-but-contracted (present with real content, identical format when present). A zone absent from this contract FAILS — no junk-drawer drift. World-class basis: Google SRE (runbook≠playbook≠postmortem, immutable blameless postmortems, on-call).",
  "referenceImplRepo": "baseline-os",
  "machineStateSoR": "operations/ (repo root) — P29 manifests, link only",
  "root": {
    "allowedFiles": ["README.md", "scorecard.md"],
    "requiredFiles": ["README.md"],
    "forbidLooseMdAtRoot": true,
    "note": "Index + scorecard only; everything else in a contracted zone."
  },
  "subfolders": {
    "runbooks": {
      "purpose": "One task per file — step-by-step, executable under pressure by someone who didn't build it.",
      "documentType": "runbook",
      "requiredFiles": ["README.md"],
      "allowedRootFiles": ["README.md"],
      "filePatternRegex": "^[a-z0-9-]+\\.md$",
      "filePatternHuman": "{system}-{action}.md",
      "forbidLooseMdAtRoot": false,
      "allowedChildFolders": [
        "operator",
        "processes",
        "assurance",
        "audit-dr",
        "incident",
        "sre",
        "archive"
      ]
    },
    "playbooks": {
      "purpose": "SRE — incident-category decision trees + roles + comms (a category, not one task).",
      "documentType": "playbook",
      "requiredFiles": ["README.md"],
      "allowedRootFiles": ["README.md"],
      "filePatternRegex": "^[a-z0-9-]+\\.md$",
      "filePatternHuman": "{category}-response.md (e.g. sev1-response.md)",
      "forbidLooseMdAtRoot": false,
      "allowedChildFolders": ["batch-a", "archive"]
    },
    "incidents": {
      "purpose": "SRE — incident records + postmortems.",
      "documentType": "incident",
      "requiredFiles": ["README.md"],
      "allowedRootFiles": [
        "README.md",
        "CODE_OF_CONDUCT.md",
        "CONTRIBUTING.md",
        "SECURITY.md",
        "root-allowlist.json"
      ],
      "forbidLooseMdAtRoot": true,
      "allowedChildFolders": ["postmortems", "archive"],
      "childContracts": {
        "postmortems": {
          "filePatternRegex": "^\\d{4}-\\d{2}-\\d{2}-[a-z0-9-]+\\.md$",
          "filePatternHuman": "YYYY-MM-DD-{slug}.md",
          "immutable": true,
          "rule": "Date-prefixed, immutable, blameless (Google SRE template)."
        }
      }
    },
    "on-call": {
      "purpose": "SRE — escalation, severity levels, being-on-call.",
      "documentType": "runbook",
      "requiredFiles": ["README.md"],
      "allowedRootFiles": ["README.md"],
      "filePatternRegex": "^[a-z0-9-]+\\.md$",
      "filePatternHuman": "{slug}.md (escalation-policy.md, severity-levels.md)",
      "forbidLooseMdAtRoot": false,
      "allowedChildFolders": ["runbooks", "archive"]
    },
    "agent-init": {
      "purpose": "Agent session entry — repo init (fleet init is AGENT-INIT-CANON in canon-os).",
      "documentType": "overview",
      "requiredFiles": ["README.md"],
      "allowedRootFiles": ["README.md", "agent-universal-instructions.md"],
      "filePatternRegex": "^[a-z0-9-]+\\.md$",
      "filePatternHuman": "{slug}.md",
      "forbidLooseMdAtRoot": false,
      "allowedChildFolders": ["protocols", "templates", "archive"]
    },
    "deployment": {
      "purpose": "Release + environment narratives.",
      "documentType": "runbook",
      "requiredFiles": ["README.md"],
      "allowedRootFiles": ["README.md"],
      "filePatternRegex": "^[a-z0-9-]+\\.md$",
      "filePatternHuman": "{slug}.md",
