      "machine/spec/finops-as-a-service.json",
      "machine/finops-friction-register.json",
      "platform/scripts/finops-check.mjs",
      "platform/scripts/cost/run-infra-cost-audit.mjs",
      "platform/scripts/cost/aws-cost-optimization-export.mjs",
      "audit/evidence/finops-check-latest.json"
    ],
    "bridgeOs": [
      "machine/spec/environment-cost-policy.json",
      "machine/spec/aws-cost-governance.json",
      "machine/spec/finops-friction-register.json",
      "machine/ci/ops-lanes-100/finops-fleet-latest.json"
    ]
  },
  "artifacts": {
    "spec": "machine/spec/finops-as-a-service.json",
    "frictionRegister": "machine/finops-friction-register.json",
    "opsEntry": "docs/operations/finops-as-a-service.md",
    "witness": "audit/evidence/finops-check-latest.json",
    "infraCostWitness": "audit/evidence/infra-aws-cost-optimization-latest.json",
    "awsOptimizationExport": "audit/evidence/aws-cost-optimization-export-latest.json",
    "deploymentStrategy": "docs/operations/deployment/infra-ai-cost-strategy-2026-06-30.md"
