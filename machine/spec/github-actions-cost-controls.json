{
  "$schema": "gtcx://fabric-os/github-actions-cost-controls/v1",
  "version": "1.0.0",
  "updated": "2026-06-30",
  "ownerRepo": "fabric-os",
  "policyDoc": "docs/operations/runbooks/github-actions-cost-controls.md",
  "deploymentOpsContract": "machine/spec/deployment-ops-contract.json",
  "checkCommand": "pnpm gha:cost-controls:check",
  "scope": {
    "workflowDirectory": ".github/workflows",
    "fleetDefaultRunner": "ubuntu-latest",
    "disallowedRunners": ["macos-latest", "macos-13", "macos-14", "windows-latest"],
    "disallowedDeploymentProviderRefs": ["vercel"],
    "scheduledWorkflowRequiresConcurrencyCancel": true,
    "scheduledWorkflowRequiresJobTimeouts": true,
    "productionCriticalPath": "aws-codebuild-and-argocd",
    "githubActionsProductionCriticalPathAllowed": false
  },
  "approvalRules": {
    "macosRunners": {
      "default": "forbidden",
      "allowedOnlyWith": [
        "documented iOS/macOS build requirement",
        "fabric-os approval",
        "expiry date",
        "budget owner"
      ]
    },
    "scheduledWorkflows": {
      "default": "manual or minimal cadence",
      "requires": ["owner", "timeout-minutes", "concurrency.cancel-in-progress=true"]
    },
    "vercel": {
      "status": "retired",
      "rule": "Do not add Vercel deployment or status-check assumptions."
    },
    "productionCiCd": {
      "default": "forbidden-on-github-actions-while-billing-blocked",
      "requiredExecutor": "aws-codebuild-vpc",
      "requiredDelivery": "argocd-in-eks",
      "rule": "GitHub Actions may be a source-control event source only; production deploy execution must run through AWS-owned execution until a superseding Class A strategy lands."
    }
  }
}
