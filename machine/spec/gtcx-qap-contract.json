{
  "$schema": "gtcx://fabric-os/gtcx-qap-contract/v1",
  "version": "1.0.0",
  "updated": "2026-06-30",
  "provider": "fabric-os",
  "service": "GTCX-QAP",
  "title": "GTCX Quality Assurance Protocol contract",
  "status": "current",
  "principle": "GTCX QAP is Fabric's repository quality acceptance service. It does not replace AaaS, MPR, SIGNAL, canon governance, bridge runtime, agile workflow, or repo-local product gates; it verifies that those owner contracts are present, current, non-contradictory, and sufficient for repository acceptance.",
  "runbook": "docs/operations/runbooks/repo-cleanup-mpr-signal-loop.md",
  "canonicalCommand": "qap:repo:acceptance",
  "compatibilityCommands": [
    "repo-cleanup:mpr-signal:acceptance"
  ],
  "acceptanceThresholds": {
    "mprComposite100": 100,
    "signalLevel": "L5",
    "signalScore100": 100,
    "governanceProtocolScore100": 100,
    "folderFileSpecScore100": 100,
    "fabricAaasDaasScore100": 100,
    "operationalLaneIsolation": true
  },
  "scoringModel": {
    "principle": "Every QAP control is scored. Binary labels are not valid QAP evidence.",
    "scoreField": "score100",
    "benchmarkField": "benchmark100",
    "belowBenchmarkRule": "score100 < benchmark100",
    "phaseLoopRule": "A phase repeats until score100 >= benchmark100, then the repo may advance to the next phase.",
    "defaultBenchmark100": 100
  },
  "ownerBoundaries": {
    "qapAcceptance": {
      "owner": "fabric-os",
      "sor": "machine/spec/gtcx-qap-contract.json",
      "witness": "audit/evidence/repo-cleanup-mpr-signal-acceptance-latest.json"
    },
    "aaasContract": {
      "owner": "fabric-os",
      "sor": "machine/spec/aaas-audit-contract.json",
      "repoPin": "machine/spec/aaas-audit-contract.pin.json"
    },
    "mprTaxonomy": {
      "owner": "fabric-os",
      "sor": "machine/spec/aaas-audit-taxonomy.json"
    },
    "mprEngine": {
      "owner": "bridge-os",
      "entrypoint": "bridge-os/platform/scripts/ecosystem/run-mpr-repo-audit.mjs",
      "witness": "audit/evidence/mpr-repo-latest.json"
    },
    "signalEvaluator": {
      "owner": "fabric-os now; baseline-os target",
      "entrypoint": "platform/scripts/aaas-signal-eval.mjs",
      "witness": "audit/evidence/signal-maturity-latest.json"
    },
    "governanceAndFolderSpecs": {
      "owner": "canon-os",
      "sor": "canon-os governance protocols and folder/file specs"
    },
    "runtimeAndPersona": {
      "owner": "bridge-os",
      "sor": "P22 runtime, persona/frame, MPR engine"
    },
    "agileWorkflow": {
      "owner": "agile-os",
      "sor": "feature registry, sprint authority, ceremonies, DoR/DoD"
    },
    "baselineRuntime": {
      "owner": "baseline-os",
      "sor": "startup/runtime conventions and command surface"
    },
    "productImplementation": {
      "owner": "repo owner",
      "sor": "repo-local code, product docs, tests, and delivery evidence"
    }
  },
  "persistence": {
    "qapReport": "audit/reports/repo-cleanup-mpr-signal-acceptance-YYYY-MM-DD.md",
    "qapWitness": "audit/evidence/repo-cleanup-mpr-signal-acceptance-latest.json",
    "inventoryWitness": "audit/evidence/repo-folder-file-spec-inventory-latest.json",
    "archiveManifest": "audit/evidence/repo-cleanup-archive-manifest-latest.json",
    "aaasContractWitness": "audit/evidence/aaas-contract-check-latest.json",
    "aaasCadenceWitness": "audit/evidence/aaas-cadence-latest.json",
    "aaasHonestyWitness": "audit/evidence/aaas-honesty-gate-latest.json",
    "aaasOwnershipWitness": "audit/evidence/aaas-ownership-latest.json",
    "mprCompositeWitness": "audit/evidence/mpr-repo-latest.json",
    "signalWitness": "audit/evidence/signal-maturity-latest.json"
  },
  "provisioning": {
    "aaasProvisionCommand": "pnpm aaas:provision:write",
    "aaasProvisionScript": "platform/scripts/aaas-provision.mjs",
    "fleetBindings": "machine/fleet-audit-contracts.json",
    "repoPin": "machine/spec/aaas-audit-contract.pin.json",
    "requiredAaasFolders": [
      "audit/evidence",
      "audit/reports",
      "audit/handoff",
      "audit/archive",
      "reports"
    ],
    "qapCommandAliases": [
      "pnpm qap:repo:acceptance",
      "pnpm qap:repo:acceptance:write",
      "pnpm repo-cleanup:mpr-signal:acceptance",
      "pnpm repo-cleanup:mpr-signal:acceptance:write"
    ],
    "notes": [
      "Fabric provisions contracts and pins; it does not copy the scoring engine into product repos.",
      "Bridge produces the MPR witness in the target repo; Fabric consumes and validates it.",
      "Repo-local ad hoc scripts must not be added to satisfy a missing upstream contract."
    ]
  },
