  "determinationRules": {
    "complete": "All QAP control rows score at or above benchmark, MPR is 100/100, SIGNAL is L5 / 100, and no blockers remain.",
    "incomplete": "Any QAP control score is below benchmark, MPR is below 100, SIGNAL is below L5 / 100, or required evidence is missing/stale.",
    "blocked": "Only valid when the remaining gap is a real Class S or external dependency with owner, evidence, and unblock path.",
    "forbidden": [
      "No product-release block from Fabric-owned operational lanes unless an explicit repo-local product contract sets blocksProductRelease: true.",
      "No ad hoc repo-local scripts to satisfy a missing upstream command contract.",
      "No symlink-only compliance.",
      "No --no-verify acceptance without an exception witness and replacement controls."
