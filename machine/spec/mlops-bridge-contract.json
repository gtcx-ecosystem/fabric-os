{
  "$schema": "gtcx://fabric-os/mlops-bridge-contract/v1",
  "version": "1.3.0",
  "updated": "2026-06-30",
  "title": "MLOps bridge — fabric-os substrate contract",
  "opsLane": "MLOps",
  "mlopsOwner": "baseline-os",
  "aiopsProgramOwner": "baseline-os",
  "fabricBridgeOwner": "fabric-os",
  "status": "scaffold",
  "principle": "MLOps and AIOps strategy is owned by baseline-os and fabric-os. baseline-os owns cost-router, eval, model governance, and CostGuard contracts. fabric-os owns deploy substrate, cost evidence, and runtime bridge controls. The bridge-os intelligence bridge consumes the runtime contract; it does not own the infra strategy.",
  "ownerSplit": {
    "baselineOs": [
      "machine/spec/mlops-as-a-service.json",
      "docs/specs/runtime/cost-router.md",
      "platform/packages/baselineos/src/core/cost-router.ts",
      "CostGuard tenant/repo budget contracts",
      "durable cost-stats by tenant/repo/model"
    ],
    "fabricOs": [
      "deploy/terraform/modules/gcp-ml-bridge/",
      "platform/tools/eval-pipeline/",
      "platform/tools/anomaly-detector/",
      "machine/spec/mlops-bridge-contract.json",
      "machine/spec/deployment-ops-contract.json",
      "docs/operations/deployment/infra-ai-cost-strategy-2026-06-30.md",
      "audit/evidence/mlops-cost-router-staging-probe-latest.json"
    ],
    "bridgeOsIntelligenceBridge": [
      "runtime service behavior",
      "inference API consumption",
      "SDK image containing baselineos/cost-router",
      "GCP Phase 3 ML artifact production when approved"
    ]
  },
  "fabricArtifacts": {
    "terraform": "deploy/terraform/modules/gcp-ml-bridge/",
    "evalPipeline": "platform/tools/eval-pipeline/",
    "modelCards": [
      "docs/governance/model-cards/anomaly-detector-model-card.md",
      "docs/governance/model-cards/eval-pipeline-model-card.md"
    ],
    "ci": "AWS CodeBuild / deployment-ops-contract; GitHub Actions is not production critical path"
  },
  "handoffs": {
    "baselineOs": "docs/operations/coordination/inbound/to-baseline-os-mlops-lane-2026-06-15.md",
    "bridgeOs": "docs/operations/coordination/inbound/to-bridge-os-ai-mlops-lane-2026-06-15.md"
  },
  "readinessGate": {
    "command": "pnpm mlops:cost-router-staging-probe:write",
    "rule": "Do not claim AI cost-router readiness until the live pod can import baselineos/cost-router."
  },
  "forbiddenStrategyOwners": ["bridge-os", "gtcx-os", "archived-intelligence-repo", "fabric-os"]
}
