{
  "$schema": "gtcx://fabric-os/qasc-contract/v1",
  "version": "1.1.0",
  "updated": "2026-07-02",
  "ownerRepo": "fabric-os",
  "title": "GTCX Quality Assurance, Security, and Compliance Protocol",
  "protocolId": "GTCX-QASC-001",
  "status": "current",
  "purpose": "Provide one scored, evidence-backed, provider-neutral quality assurance, security, and compliance loop for every active GTCX repository.",
  "auditRequirementsRef": "machine/spec/qasc-audit-requirements.json",
  "authority": {
    "governanceAndFolderSpecs": "canon-os",
    "mprSignalAndRuntimeEngines": "bridge-os",
    "qualityAssuranceService": "fabric-os",
    "agileWorkflow": "agile-os",
    "runtimeConventions": "baseline-os",
    "implementation": "repo owner"
  },
  "benchmarks": {
    "repositoryScore100": 100,
    "controlScore100": 100,
    "mprComposite100": 100,
    "signalLevel": "L5",
    "signalScore100": 100,
    "agileProductionPackageWorkflow100": 100
  },
  "enforcementModel": {
    "alwaysEnforced": [
      "quality and evidence integrity controls",
      "secure engineering and configuration controls",
      "privacy and compliance implementation controls",
      "regulatory control mappings and traceability",
      "folder, documentation, workflow, and cross-repo contracts"
    ],
    "parallelExternalAssurance": [
      "external auditor opinions and certifications",
      "vendor penetration-test delivery",
      "legal countersignatures and procurement decisions",
      "observation-period evidence controlled by elapsed time"
    ],
    "releaseBoundary": "Every control remains scored and auditable. External assurance does not block engineering or product release unless the owning repository has an explicit, versioned release contract with blocksProductRelease=true for that exact control.",
    "claimBoundary": "A self-audit can verify implementation and evidence readiness; it cannot claim an external certification, legal determination, or auditor opinion."
  },
  "loop": {
    "mode": "agent-mediated-remediation",
    "maxIterations": 10,
    "stagnantLimit": 2,
    "stopReasons": ["benchmark-reached", "stagnant", "max-iterations", "unreadable-witness"],
    "rule": "Observe scores, remediate the first owner-appropriate below-benchmark phase, regenerate evidence, and restart at Phase 1. Repetition without a remediation is measurement, not convergence.",
    "handoffRequiredWhen": ["stagnant", "max-iterations", "unreadable-witness"]
  },
  "deletionPreservationPolicy": {
    "id": "QASC-DELETE-PRESERVE-001",
    "scoreTarget100": 100,
    "rule": "Tracked files must not be removed as bare deletes during repo cleanup. Retired, superseded, decomposed, or disallowed active-tree content must be moved to archive/_delete/<reason-date>/... so Git records a recoverable relocation.",
    "currentWorktreeGate": "Any current D status outside archive/_delete scores 0 for current deletion preservation until converted to an archive/_delete move.",
    "historicalAuditGate": "Any commit in the audit window with tracked D entries and no same-commit archive/_delete relocation is a historical preservation gap requiring forward-repair assessment.",
    "command": "pnpm qasc:deletion-preservation:audit",
    "witness": "audit/evidence/qasc-deletion-preservation-audit-latest.json",
    "report": "audit/reports/qasc-deletion-preservation-audit-YYYY-MM-DD.md"
  },
  "phases": [
    "sessionGuard",
    "inventoryAndClassification",
    "documentationTaxonomyLifecycle",
    "featureSpecRegistryPrd",
    "roadmapGoalsMilestonesWorkstream",
    "operationalLaneIsolation",
    "foundationalMicroAudits",
    "transformationalMicroAudits",
    "folderFileSpecs",
    "preservationArchiveProof",
    "ownerWorkflowValidation",
    "consumerContractValidation",
    "fabricAaasDaasVerification",
    "mprSignalScoring",
    "remediationLoop",
    "acceptanceCommitPushHandoff"
  ],
  "requiredControls": [
    "Worktree clean",
    "Critical docs preserved",
    "Feature/spec registry",
    "Documentation hygiene",
    "Folder/file/product spec alignment",
    "Roadmap/goals/milestones",
    "Agile workflow",
    "Ops contract",
    "P22/runtime",
    "Fabric AaaS/DaaS",
    "Security implementation controls",
    "Compliance implementation controls",
    "Operational lane isolation",
    "MPR composite",
    "SIGNAL maturity",
    "Foundational micro-audits",
    "Transformational micro-audits",
    "Product-intent source",
    "Machine-readable standardization",
    "Forensic spec",
    "Package MPR",
    "Package SIGNAL",
    "Production spec package",
    "Scrum handoff",
    "Backlog compatibility only",
    "Root hygiene",
    "Link/reference hygiene",
    "Cross-repo contract",
    "Archive recoverability",
    "Deletion preservation policy"
  ],
  "fleet": {
    "denominatorPolicy": "Explicit active checkout list. Changes require a versioned contract update; deployment or legacy rollout registries cannot silently narrow QASC coverage.",
    "repos": [
      "agile-os",
      "baseline-os",
      "bridge-os",
      "canon-os",
      "compliance-os",
      "ecosystem-os",
      "exploration-os",
      "fabric-os",
      "griot-ai",
      "gtcx-os",
      "inspection-os",
      "ledger-os",
      "ledger-ui",
      "markets-os",
      "nyota-ai",
      "sensei-os",
      "terminal-os",
      "terra-os",
      "venture-os",
      "veritas-ai"
    ]
  },
  "commands": {
    "repositoryScore": "pnpm qasc:repo -- --repo <repo>",
    "repositoryLoop": "pnpm qasc:loop -- --repo <repo>",
    "fleetScore": "pnpm qasc:fleet",
    "fleetEvidence": "pnpm qasc:fleet:write",
    "fleetEnforcement": "pnpm qasc:fleet:strict",
    "deletionPreservationAudit": "pnpm qasc:deletion-preservation:audit -- --since 2026-06-02T00:00:00",
    "deletionPreservationEvidence": "pnpm qasc:deletion-preservation:audit:write -- --since 2026-06-02T00:00:00",
    "deletionPreservationEnforcement": "pnpm qasc:deletion-preservation:audit:strict -- --since 2026-06-02T00:00:00",
    "contractEnforcement": "pnpm qasc:contract:check",
    "tests": "pnpm qasc:test"
  },
  "evidence": {
    "repository": "audit/evidence/qasc-repo-latest.json",
    "repositoryLoop": "audit/evidence/qasc-loop-latest.json",
    "fleet": "audit/evidence/qasc-fleet-latest.json",
    "deletionPreservation": "audit/evidence/qasc-deletion-preservation-audit-latest.json",
    "fleetReport": "audit/reports/qasc-fleet-YYYY-MM-DD.md"
  }
}
