    "assurance": { "owner": "fabric-os + bridge-os", "pmLeads": false, "blocksIRDefault": false }
  },
  "ownerSplit": {
    "fabricOs": [
      "pm/spec/aiops-as-a-service.json",
      "pm/aiops-friction-register.json",
      "pm/aiops-signals-register.json",
      "docs/operations/aiops-as-a-service.md",
      "docs/operations/aiops-agentic-team.md",
      "platform/scripts/aiops-check.mjs",
      "platform/scripts/tests/aiops-check.test.mjs",
      "audit/evidence/aiops-check-latest.json"
    ],
    "intelligenceOwner": ["model serving runtime", "inference eval rubrics"],
    "bridgeOs": ["ecosystem:aiops:check:fleet", "pm/ci/aiops-fleet-latest.json"],
    "mlopsBridge": ["pm/spec/mlops-bridge-contract.json", "deploy/terraform/modules/gcp-ml-bridge/"]
  },
  "artifacts": {
    "spec": "pm/spec/aiops-as-a-service.json",
    "runbook": "docs/operations/aiops-as-a-service.md",
    "teamCharter": "docs/operations/aiops-agentic-team.md",
