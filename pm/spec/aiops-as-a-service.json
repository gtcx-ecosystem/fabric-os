    "check": "platform/scripts/aiops-check.mjs",
    "checkTest": "platform/scripts/tests/aiops-check.test.mjs",
    "witness": "audit/evidence/aiops-check-latest.json",
    "fleetWitness": "../bridge-os/pm/ci/aiops-fleet-latest.json"
  },
  "harness": {
    "check": "pnpm aiops:check",
    "write": "pnpm aiops:check:write",
    "fleet": "pnpm --dir ../bridge-os ecosystem:aiops:check:fleet:write"
